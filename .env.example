# Environment Configuration — AegisLab
# Copy to .env and fill in values before running.

# ── Identity / JWT ─────────────────────────────────────────────
AEGISLAB_JWT_PRIVATE_KEY_PATH=keys/private.pem
AEGISLAB_JWT_PUBLIC_KEY_PATH=keys/public.pem
AEGISLAB_TOKEN_TTL_SECONDS=900
AEGISLAB_JWT_ALGORITHM=RS256
AEGISLAB_JWT_ISSUER=aegislab

# ── Policy Engine ──────────────────────────────────────────────
AEGISLAB_POLICY_DIR=policies/
AEGISLAB_DEFAULT_POLICY=deny   # deny | allow

# ── Redis (rate limits, circuit breakers) ─────────────────────
AEGISLAB_REDIS_URL=redis://localhost:6379/0

# ── Egress Proxy ──────────────────────────────────────────────
AEGISLAB_EGRESS_PROXY_PORT=8888
AEGISLAB_EGRESS_PROXY_HOST=127.0.0.1
AEGISLAB_EGRESS_ALLOW_DOMAINS=

# ── Injection Defenses ────────────────────────────────────────
AEGISLAB_INJECTION_THRESHOLD=0.7
AEGISLAB_INJECTION_REVIEW_THRESHOLD=0.4

# ── Human Approval ────────────────────────────────────────────
AEGISLAB_HUMAN_APPROVAL_WEBHOOK=
AEGISLAB_HUMAN_APPROVAL_TIMEOUT_SECONDS=300

# ── Container Sandbox ─────────────────────────────────────────
AEGISLAB_SANDBOX_DRIVER=docker   # docker | subprocess (dev only)
AEGISLAB_CONTAINER_IMAGE=python:3.11-slim
AEGISLAB_CONTAINER_MEMORY_LIMIT=256m
AEGISLAB_CONTAINER_CPU_QUOTA=50000   # 50% of one CPU

# ── API Server ────────────────────────────────────────────────
AEGISLAB_API_HOST=0.0.0.0
AEGISLAB_API_PORT=8000
AEGISLAB_LOG_LEVEL=INFO

# ── Observability ────────────────────────────────────────────
AEGISLAB_TRACE_LOG_FILE=logs/traces.jsonl
AEGISLAB_METRICS_PORT=9090
